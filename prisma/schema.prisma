datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  fullName      String?
  avatarUrl     String?
  bio           String?
  resumeUrl     String?
  githubUrl     String?
  twitterUrl    String?
  linkedinUrl   String?
  certifications String?
  role          String    @default("MEMBER")
  permissions   String?
  score         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  notes         Note[]
  resources     Resource[]
  bookmarks     Bookmark[]
  upvotes       Upvote[]
  events        Event[]
  notifications Notification[]
  adminRequests AdminRequest[]
  steps         RoadmapStep[]
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String
  coverImage  String?
  tags        String
  readTime    Int      @default(0)
  views       Int      @default(0)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  bookmarks   Bookmark[]
  upvotes     Upvote[]
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  url         String
  imageUrl    String?
  tags        String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  bookmarks   Bookmark[]
  upvotes     Upvote[]
}

model Event {
  id           String    @id @default(cuid())
  title        String
  description  String
  type         String
  startTime    DateTime
  endTime      DateTime? // Optional end time — used to detect ongoing events
  externalLink String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  status       String    @default("PENDING")
  imageUrls    String?
  feedback     String?
  tags         String    @default("")

  authorId        String?
  author          User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)

  interestedCount Int        @default(0)
  bookmarks       Bookmark[]
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ToolComparison {
  id          String   @id @default(cuid())
  title       String
  toolA       String
  toolB       String
  prosA       String
  consA       String
  prosB       String
  consB       String
  useCaseA    String
  useCaseB    String
  verdict     String
  tags        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]
}

model CertGuide {
  id          String   @id @default(cuid())
  name        String
  description String
  difficulty  Int
  prepTime    String
  passScore   String
  content     String
  resources   String
  tags        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  createdAt  DateTime @default(now())
  itemType   String

  noteId     String?
  resourceId String?
  toolId     String?
  certId     String?
  stepId     String?
  eventId    String?
  remindMe   Boolean   @default(false)

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       Note?           @relation(fields: [noteId], references: [id], onDelete: Cascade)
  resource   Resource?       @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tool       ToolComparison? @relation(fields: [toolId], references: [id], onDelete: Cascade)
  cert       CertGuide?      @relation(fields: [certId], references: [id], onDelete: Cascade)
  step       RoadmapStep?    @relation(fields: [stepId], references: [id], onDelete: Cascade)
  event      Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Upvote {
  id         String   @id @default(cuid())
  userId     String
  createdAt  DateTime @default(now())
  itemType   String

  noteId     String?
  resourceId String?
  stepId     String?

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)
  resource   Resource?    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  step       RoadmapStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model AdminRequest {
  id        String   @id @default(cuid())
  userId    String
  reason    String?
  category  String   @default("GENERAL")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  reason    String
  message   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Roadmap {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("🗺️")
  color       String   @default("#3B82F6")
  order       Int      @default(0)
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       RoadmapStep[]
}

model RoadmapStep {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("📦")
  order       Int      @default(0)
  status      String   @default("PENDING")
  tags        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmapId   String?
  roadmap     Roadmap?  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)

  topics      RoadmapTopic[]
  resources   RoadmapResource[]
  bookmarks   Bookmark[]
  upvotes     Upvote[]
}

model RoadmapTopic {
  id        String   @id @default(cuid())
  title     String
  content   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stepId    String
  step      RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  subtopics RoadmapSubTopic[]
}

model RoadmapSubTopic {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topicId   String
  topic     RoadmapTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model RoadmapResource {
  id               String   @id @default(cuid())
  title            String
  url              String
  type             String
  description      String?
  imageUrl         String?
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  globalResourceId String?

  stepId           String
  step             RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
}
